DATABASE_URL=postgresql://contentnode:contentnode_dev@localhost:5432/contentnode
REDIS_URL=redis://localhost:6379

# Clerk — get from https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_...

# AI providers — set whichever you use
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Brave Search API — unlocks external company enrichment in GTM Assessment scrape
# (Pitchbook, Crunchbase, LinkedIn, ZoomInfo snippets via search results)
# Free tier: 2,000 queries/month — sign up at https://api.search.brave.com/
# Without this key, enrichment uses only the company's own website + DDG Instant Answer
BRAVE_SEARCH_API_KEY=

# CORS origin for the web app
CORS_ORIGIN=http://localhost:3000

PORT=3001
LOG_LEVEL=info

# Encryption key for OAuth tokens at rest — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Wrike OAuth integration
WRIKE_CLIENT_ID=
WRIKE_CLIENT_SECRET=

# Monday.com integration
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=
MONDAY_SIGNING_SECRET=
MONDAY_API_TOKEN=
MONDAY_REDIRECT_URI=
