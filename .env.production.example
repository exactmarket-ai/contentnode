# ─────────────────────────────────────────────────────────────────────────────
# ContentNode — Production Environment Variables
# Store these in AWS Secrets Manager under /contentnode/production/<KEY>
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# RDS PostgreSQL connection string (with pgvector extension enabled)
DATABASE_URL=postgresql://contentnode:<password>@<rds-endpoint>:5432/contentnode?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
# ElastiCache Redis (cluster mode off for BullMQ compatibility)
REDIS_URL=redis://<elasticache-endpoint>:6379

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# ── AI Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=                        # leave blank in production (online mode)

# ── Humanizer Services ────────────────────────────────────────────────────────
HUMANIZER_SERVICE=undetectable          # default service: undetectable | bypassgpt
UNDETECTABLE_API_KEY=...
BYPASSGPT_API_KEY=...

# ── Detection Services ────────────────────────────────────────────────────────
GPTZERO_API_KEY=...
ORIGINALITY_API_KEY=...
SAPLING_API_KEY=...

# ── Translation ───────────────────────────────────────────────────────────────
DEEPL_API_KEY=...                       # ends in :fx for free tier
GOOGLE_TRANSLATE_API_KEY=...

# ── File Storage (S3 / Cloudflare R2) ────────────────────────────────────────
# AWS S3:
S3_BUCKET=contentnode-uploads-production
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Cloudflare R2 (alternative — uses S3-compatible API):
# S3_BUCKET=contentnode-uploads
# S3_REGION=auto
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# AWS_ACCESS_KEY_ID=<r2-access-key-id>
# AWS_SECRET_ACCESS_KEY=<r2-secret>

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
FROM_EMAIL=noreply@yourdomain.com       # must be a verified SendGrid sender
FROM_NAME=ContentNode

# ── App URLs ──────────────────────────────────────────────────────────────────
PORTAL_BASE_URL=https://app.yourdomain.com

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Misc ──────────────────────────────────────────────────────────────────────
# DEV_CLIENT_ID is only used in dev — remove in production
# DEV_CLIENT_ID=
