  @@index([agencyId])
  @@index([source])
  @@map("client_brain_attachments")
}

// CampaignBrainAttachment — per-file brain docs for a campaign
// ─────────────────────────────────────────────
model CampaignBrainAttachment {
  id         String   @id @default(cuid())
  agencyId   String   @map("agency_id")
  campaignId String   @map("campaign_id")
  filename   String
  storageKey String?  @map("storage_key")   // null for URL-only sources
  sourceUrl  String?  @map("source_url")
  mimeType   String   @default("") @map("mime_type")
  sizeBytes  Int      @default(0) @map("size_bytes")
  // pending | processing | ready | failed
  extractionStatus String @default("pending") @map("extraction_status")
  extractedText    String? @db.Text @map("extracted_text")
  // pending | processing | ready | failed
  summaryStatus    String  @default("pending") @map("summary_status")
  summary          String? @db.Text
  // when true, this doc is only injected for this campaign's runs (experimental content)
  campaignScopedOnly Boolean @default(false) @map("campaign_scoped_only")
  uploadedByUserId   String? @map("uploaded_by_user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([agencyId])
  @@map("campaign_brain_attachments")
}

// ─────────────────────────────────────────────
// Program — standing content engine (Thought Leadership, SEO, etc.)
// Linked to a ScheduledTask as research feed. Produces WorkflowRuns
// that land in Pipeline for review before publish.
// ─────────────────────────────────────────────
model Program {
  id              String    @id @default(cuid())
  agencyId        String    @map("agency_id")
  clientId        String    @map("client_id")
  verticalId      String?   @map("vertical_id")
  name            String
  // thought_leadership | seo_content | newsletter | social_media |
  // outbound_email_sequence | linkedin_outreach_sequence | cold_calling_program |
  // email_nurture_sequence | lead_magnet_program | webinar_event_program |
  // abm_program | customer_onboarding_program | reengagement_program |
  // partner_enablement_program | product_launch_program |
  // competitive_intel | customer_story | event_content (legacy)
  type            String
  status          String    @default("active") // active | paused | archived
  executionModel  String    @default("recurring") @map("execution_model") // recurring | one_time
  // setup | think | build | complete
  pilotPhase      String    @default("setup") @map("pilot_phase")
  scheduledTaskId String?   @map("scheduled_task_id")
  // Vertical program template this was cloned from (if any)
  templateId      String?   @map("template_id")
  contentConfig   Json      @default("{}") @map("content_config")
  brief           String?   @db.Text // written program brief from Phase 1
  briefEditedAt   DateTime? @map("brief_edited_at")
  cadence         String?   // human label: "Weekly", "Bi-weekly", "Monthly"
  cadenceCronExpr String?   @map("cadence_cron_expr")
  autoPublish     Boolean   @default(false) @map("auto_publish")
  pilotMessages   Json?     @map("pilot_messages") // full conversation history for resuming
  pilotContext    Json?     @map("pilot_context")  // legacy — kept for backward compat
  setupComplete   Boolean   @default(false) @map("setup_complete")
  lastRunAt       DateTime? @map("last_run_at")
  nextRunAt       DateTime? @map("next_run_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  agency        Agency                @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client        Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vertical      Vertical?             @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  scheduledTask ScheduledTask?        @relation(fields: [scheduledTaskId], references: [id], onDelete: SetNull)
  template      VerticalProgramTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  workflowRuns  WorkflowRun[]
  contentPacks  ProgramContentPack[]

  @@index([agencyId])
  @@index([clientId])
  @@index([verticalId])
  @@map("programs")
}

// ─────────────────────────────────────────────
// ProgramContentPack — one cycle's output
// For recurring programs: one pack per cycle.
// For one-time programs: one pack containing all templates (isTemplate=true items).
// ─────────────────────────────────────────────
model ProgramContentPack {
  id           String    @id @default(cuid())
  agencyId     String    @map("agency_id")
  clientId     String    @map("client_id")
  programId    String    @map("program_id")
  cycleLabel   String    @map("cycle_label")  // "Week of Apr 21, 2026" or "v1 — Setup"
  status       String    @default("draft")    // draft | in_review | approved | archived
  reviewStatus String    @default("none") @map("review_status") // none | pending | sent_to_client | approved
  sourceTaskId String?   @map("source_task_id")
  sourceLabel  String?   @map("source_label")
  assigneeId   String?   @map("assignee_id")
  dueDate      DateTime? @map("due_date")
  notes        String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  agency   Agency               @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client   Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  program  Program              @relation(fields: [programId], references: [id], onDelete: Cascade)
  items    ProgramContentItem[]

  @@index([agencyId])
  @@index([programId])
  @@index([clientId])
  @@map("program_content_packs")
}

// ─────────────────────────────────────────────
// ProgramContentItem — one deliverable within a pack
// blog | linkedin_post | instagram_post | facebook_post | x_post |
// email | voicemail_script | call_script | objection_guide | discovery_questions |
// newsletter_issue | lead_magnet_doc | landing_page_copy | press_release |
// onepager | webinar_invite | event_social | onboarding_email | sequence_template
// ─────────────────────────────────────────────
model ProgramContentItem {
  id            String   @id @default(cuid())
  packId        String   @map("pack_id")
  itemType      String   @map("item_type")
  label         String   // e.g. "Email 1 — Cold Intro", "LinkedIn Connection Request"
  content       String   @db.Text
  editedContent String?  @db.Text @map("edited_content")
  metadata      Json     @default("{}") // { subject?, preheader?, imagePrompt?, platform?, sequenceStep?, wordCount?, slug? }
  sortOrder     Int      @default(0) @map("sort_order")
  isTemplate    Boolean  @default(false) @map("is_template") // true = reusable template from Phase 2
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  pack ProgramContentPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([packId])
  @@map("program_content_items")
}

// ─────────────────────────────────────────────
// VerticalProgramTemplate — agency-defined program template at the vertical level
// Reusable across all clients in a vertical. When instantiated for a client,
// a new Program is created with templateId pointing here.
// ─────────────────────────────────────────────
model VerticalProgramTemplate {
  id            String   @id @default(cuid())
  agencyId      String   @map("agency_id")
  verticalId    String   @map("vertical_id")
  name          String
  type          String   // same type values as Program
  executionModel String  @default("recurring") @map("execution_model")
  brief         String?  @db.Text
  contentConfig Json     @default("{}") @map("content_config")
  cadence       String?
  templateItems Json     @default("[]") @map("template_items") // array of { itemType, label, contentHint }
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  agency    Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  vertical  Vertical  @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  programs  Program[]

  @@index([agencyId])
  @@index([verticalId])
  @@map("vertical_program_templates")
}

// ─────────────────────────────────────────────
// AgencyBrainAttachment — tier 1: agency-wide knowledge
// Methodology, playbooks, team expertise, agency voice.
// Always included in context. Never contains client data.
// ─────────────────────────────────────────────
model AgencyBrainAttachment {
  id               String   @id @default(cuid())
  agencyId         String   @map("agency_id")
  filename         String
  storageKey       String?  @map("storage_key")
  sourceUrl        String?  @map("source_url")
  mimeType         String   @default("") @map("mime_type")
  sizeBytes        Int      @default(0) @map("size_bytes")
  // pending | processing | ready | failed
  extractionStatus String   @default("pending") @map("extraction_status")
  extractedText    String?  @db.Text @map("extracted_text")
  // pending | processing | ready | failed
  summaryStatus    String   @default("pending") @map("summary_status")
  summary          String?  @db.Text
  uploadedByUserId String?  @map("uploaded_by_user_id")
  // file | url | note
  uploadMethod     String   @default("file") @map("upload_method")
  createdAt        DateTime @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@map("agency_brain_attachments")
}

// ─────────────────────────────────────────────
// VerticalBrainAttachment — tier 2: vertical-level knowledge
// Industry research, trends, weekly briefs.
// Included for all clients tagged to this vertical.
// One copy per vertical — no duplication across clients.
// ─────────────────────────────────────────────
model VerticalBrainAttachment {
  id               String   @id @default(cuid())
  agencyId         String   @map("agency_id")
  verticalId       String   @map("vertical_id")
  filename         String
  storageKey       String?  @map("storage_key")
  sourceUrl        String?  @map("source_url")
  mimeType         String   @default("") @map("mime_type")
  sizeBytes        Int      @default(0) @map("size_bytes")
  // pending | processing | ready | failed
  extractionStatus String   @default("pending") @map("extraction_status")
  extractedText    String?  @db.Text @map("extracted_text")
  // pending | processing | ready | failed
  summaryStatus    String   @default("pending") @map("summary_status")
  summary          String?  @db.Text
  uploadedByUserId String?  @map("uploaded_by_user_id")
  // file | url | note
  uploadMethod     String   @default("file") @map("upload_method")
  createdAt        DateTime @default(now()) @map("created_at")

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  vertical Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([verticalId])
  @@map("vertical_brain_attachments")
}

// ─────────────────────────────────────────────
// ClientVerticalBrainAttachment — tier 4: client × vertical knowledge
// Client-specific knowledge for a specific vertical.
// Hard firewall: never shared with other clients.
// e.g. GE Aerospace ≠ GE Appliances — same client, different vertical brains.
// ─────────────────────────────────────────────
model ClientVerticalBrainAttachment {
  id               String   @id @default(cuid())
  agencyId         String   @map("agency_id")
  clientId         String   @map("client_id")
  verticalId       String   @map("vertical_id")
  filename         String
  storageKey       String?  @map("storage_key")
  sourceUrl        String?  @map("source_url")
  mimeType         String   @default("") @map("mime_type")
  sizeBytes        Int      @default(0) @map("size_bytes")
  // pending | processing | ready | failed
  extractionStatus String   @default("pending") @map("extraction_status")
  extractedText    String?  @db.Text @map("extracted_text")
  // pending | processing | ready | failed
  summaryStatus    String   @default("pending") @map("summary_status")
  summary          String?  @db.Text
  uploadedByUserId String?  @map("uploaded_by_user_id")
  // file | url | note
  uploadMethod     String   @default("file") @map("upload_method")
  createdAt        DateTime @default(now()) @map("created_at")

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vertical Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([clientId])
  @@index([clientId, verticalId])
  @@map("client_vertical_brain_attachments")
}

// ─────────────────────────────────────────────
// ScheduledTask — recurring research task
// ─────────────────────────────────────────────
model ScheduledTask {
  id                String    @id @default(cuid())
  agencyId          String    @map("agency_id")
  clientId          String?   @map("client_id")
  verticalId        String?   @map("vertical_id")
  scope             String    // 'company' | 'client' | 'vertical'
  type              String    // 'web_scrape' | 'review_miner' | 'audience_signal' | 'seo_intent'
  label             String
  config            Json      @default("{}")
  frequency         String    @default("weekly") // 'daily' | 'weekly' | 'monthly'
  enabled           Boolean   @default(true)
  lastRunAt         DateTime? @map("last_run_at")
  nextRunAt         DateTime? @map("next_run_at")
  lastStatus        String    @default("idle") @map("last_status")
  lastOutputHash    String?   @map("last_output_hash")
  lastChangeSummary String?   @db.Text @map("last_change_summary")
  changeDetected         Boolean  @default(false) @map("change_detected")
  autoGenerate           Boolean  @default(false) @map("auto_generate")
  autoGenerateBlogCount  Int      @default(2)     @map("auto_generate_blog_count")
  contentMode            String   @default("off") @map("content_mode") // 'off' | 'auto_generate' | 'evaluate_and_queue'
  scheduledDay           Int?                     @map("scheduled_day")
  assigneeId             String?                  @map("assignee_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  agency       Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vertical     Vertical?     @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  assignee     User?         @relation("ScheduledTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  usageRecords UsageRecord[]

  programs    Program[]
  topicQueue  TopicQueue[]

  @@index([agencyId])
  @@index([clientId])
  @@index([agencyId, enabled, nextRunAt])
  @@map("scheduled_tasks")
}

// ─────────────────────────────────────────────
// DocTemplate — uploaded Word template with AI variable suggestions
// ─────────────────────────────────────────────
model DocTemplate {
  id            String   @id @default(cuid())
  agencyId      String   @map("agency_id")
  name          String
  docType       String   @default("gtm") @map("doc_type")
  originalKey   String   @map("original_key")
  processedKey  String?  @map("processed_key")
  htmlPreview   String?  @db.Text @map("html_preview")
  suggestions   Json     @default("[]")
  confirmedVars Json     @default("[]") @map("confirmed_vars")
  status        String   @default("pending")
  errorMessage  String?  @map("error_message")
  sizeBytes     Int      @default(0) @map("size_bytes")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  agency      Agency                  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  assignments DocTemplateAssignment[]

  @@index([agencyId])
  @@map("doc_templates")
}

// ─────────────────────────────────────────────
// ProspectAssessment — agency-level market positioning & competitive assessment
// ─────────────────────────────────────────────
model ProspectAssessment {
  id           String   @id @default(cuid())
  agencyId     String   @map("agency_id")
  name         String
  url          String?
  industry     String?
  status       String   @default("not_started")
  source       String   @default("manual")
  scores       Json?
  findings     Json?
  notes        String?  @db.Text
  totalScore   Float?   @map("total_score")
  serviceMap       String?  @map("service_map")       @db.Text
  execPresentation String?  @map("exec_presentation") @db.Text
  slideDeck        String?  @map("slide_deck")        @db.Text
  createdById      String?  @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  agency    Agency               @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  snapshots AssessmentSnapshot[]

  @@index([agencyId])
  @@map("prospect_assessments")
}

// ─────────────────────────────────────────────
// AssessmentSnapshot — historical run records for a ProspectAssessment
// ─────────────────────────────────────────────
model AssessmentSnapshot {
  id           String   @id @default(cuid())
  agencyId     String   @map("agency_id")
  assessmentId String   @map("assessment_id")
  source       String   @default("full")   // "full" | "quick"
  findings     Json?
  scores       Json?
  totalScore   Float?   @map("total_score")
  pagesScraped Int?     @map("pages_scraped")
  createdAt    DateTime @default(now()) @map("created_at")

  agency     Agency             @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  assessment ProspectAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([agencyId])
  @@map("assessment_snapshots")
}

// ─────────────────────────────────────────────
// DocTemplateAssignment — maps a template to a scope (client / vertical / doc type / agency default)
// ─────────────────────────────────────────────
model DocTemplateAssignment {
  id            String   @id @default(cuid())
  agencyId      String   @map("agency_id")
  templateId    String   @map("template_id")
  clientId      String?  @map("client_id")
  verticalId    String?  @map("vertical_id")
  docType       String?  @map("doc_type")
  agencyDefault Boolean  @default(false) @map("agency_default")
  createdAt     DateTime @default(now()) @map("created_at")

  agency   Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  template DocTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([templateId])
  @@map("doc_template_assignments")
}

// ─────────────────────────────────────────────
// LeadershipMember — executive thought leadership profiles
// ─────────────────────────────────────────────
model LeadershipMember {
  id               String   @id @default(cuid())
  agencyId         String   @map("agency_id")
  clientId         String   @map("client_id")
  name             String
  role             String
  linkedInUrl      String?  @map("linkedin_url")
  headshotUrl      String?  @map("headshot_url")
  bio              String?  @db.Text
  personalTone     String?  @db.Text @map("personal_tone")
  signatureTopics  Json     @default("[]") @map("signature_topics")
  signatureStories Json     @default("[]") @map("signature_stories")
  avoidPhrases     Json     @default("[]") @map("avoid_phrases")
  defaultContentPackId String?  @map("default_content_pack_id")
  mondayBoardId        String?  @map("monday_board_id")
  mondayColumnMapping  Json?    @map("monday_column_mapping")
  boxFolderId          String?  @map("box_folder_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  defaultContentPack   ContentPack? @relation("MemberDefaultPack", fields: [defaultContentPackId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([clientId])
  @@map("leadership_members")
}

// ─────────────────────────────────────────────
// Notification — in-app alerts for team members
// ─────────────────────────────────────────────
model Notification {
  id              String   @id @default(cuid())
  agencyId        String   @map("agency_id")
  userId          String   @map("user_id")
  type            String   // 'assignment' | 'comment' | 'review_ready' | 'newsroom_research'
  title           String
  body            String?  @db.Text
  resourceId      String?  @map("resource_id")      // e.g. workflowRunId or jobId
  resourceType    String?  @map("resource_type")    // e.g. 'run' | 'newsroom_research'
  clientId        String?  @map("client_id")
  read            Boolean  @default(false)
  referenceId     String?  @map("reference_id")     // jobId for updateable notifications
  referenceStatus String?  @map("reference_status") // 'pending' | 'complete' | 'failed'
  createdAt       DateTime @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agencyId, userId, read])
  @@index([agencyId, userId, createdAt(sort: Desc)])
  @@index([referenceId])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// ResearchJob — tracks async newsroom research runs
// ─────────────────────────────────────────────
model ResearchJob {
  id            String    @id @default(cuid())
  agencyId      String    @map("agency_id")
  clientId      String    @map("client_id")
  verticalId    String?   @map("vertical_id")
  userId        String?   @map("user_id")
  userInput     String    @db.Text @map("user_input")
  status        String    @default("pending") @map("status") // pending|building|searching|evaluating|complete|failed
  currentStep   String?   @map("current_step")
  recencyWindow String    @default("7d") @map("recency_window")
  topicCount    Int?      @map("topic_count")
  newTopicIds   Json      @default("[]") @map("new_topic_ids")
  errorMessage  String?   @db.Text @map("error_message")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  agency   Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vertical Vertical? @relation(fields: [verticalId], references: [id], onDelete: SetNull)

  @@index([agencyId, clientId])
  @@index([status])
  @@map("research_jobs")
}

// ─────────────────────────────────────────────
// Integration — third-party OAuth connections
// ─────────────────────────────────────────────
model Integration {
  id           String    @id @default(cuid())
  agencyId     String    @map("agency_id")
  provider     String    // 'wrike'
  accessToken  String    @map("access_token") @db.Text
  refreshToken String?   @map("refresh_token") @db.Text
  expiresAt    DateTime? @map("expires_at")
  metadata     Json?     // provider-specific data (wrike host, etc.)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, provider])
  @@map("integrations")
}

// ─────────────────────────────────────────────
// MondayWebhook — persisted record of a webhook registered on a Monday board.
// Allows listing/deleting subscriptions without round-tripping Monday's API.
// ─────────────────────────────────────────────
model MondayWebhook {
  id         String   @id @default(cuid())
  agencyId   String   @map("agency_id")
  boardId    String   @map("board_id")      // Monday board ID the subscription targets
  webhookId  String   @unique @map("webhook_id")  // Monday's returned webhook ID
  event      String                          // e.g. change_status_column_value
  createdAt  DateTime @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, boardId])
  @@map("monday_webhooks")
}

// ─────────────────────────────────────────────
// SkillSessionTemplate — saved question paths from productPILOT sessions
// ─────────────────────────────────────────────
model SkillSessionTemplate {
  id              String   @id @default(cuid())
  agencyId        String   @map("agency_id")
  skillKey        String   @map("skill_key")
  categoryKey     String   @map("category_key")
  name            String
  questionFlow    Json     @map("question_flow")   // string[] — ordered assistant questions
  createdByUserId String?  @map("created_by_user_id")
  useCount        Int      @default(0) @map("use_count")
  createdAt       DateTime @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId, skillKey])
  @@map("skill_session_templates")
}

// ─────────────────────────────────────────────
// FrameworkRevision — tracks export/review lifecycle for GTM Framework docs
// ─────────────────────────────────────────────
model FrameworkRevision {
  id             String    @id @default(cuid())
  agencyId       String    @map("agency_id")
  clientId       String    @map("client_id")
  verticalId     String    @map("vertical_id")
  // draft | agency_review | sent_to_client | client_responded | closed
  reviewStatus   String    @default("draft")    @map("review_status")
  // internal | client | internal_post | final
  revisionType   String    @default("internal") @map("revision_type")
  assigneeId     String?   @map("assignee_id")
  dataSnapshot   Json?     @map("data_snapshot")
  clientSnapshot Json?     @map("client_snapshot")
  styleSignals   Json?     @map("style_signals")
  notes          String?   @db.Text
  exportedAt     DateTime? @map("exported_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  agency   Agency   @relation(fields: [agencyId],   references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId],   references: [id], onDelete: Cascade)
  vertical Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@index([clientId, verticalId])
  @@index([agencyId])
  @@map("framework_revisions")
}

// ─────────────────────────────────────────────
// BoxFileTracking — links a Box file to a WorkflowRun so webhook events
// can be routed back to the right run/client/stakeholder.
// Created at file upload time; deleted when run is archived.
// ─────────────────────────────────────────────
model BoxFileTracking {
  id              String    @id @default(cuid())
  agencyId        String    @map("agency_id")
  clientId        String    @map("client_id")
  runId           String    @map("run_id")
  stakeholderId   String?   @map("stakeholder_id")   // primary intended recipient (nullable — not always known at upload time)
  boxFileId       String    @unique @map("box_file_id")
  boxWebhookId    String?   @map("box_webhook_id")   // null until webhook registered
  boxFolderId     String    @map("box_folder_id")
  filename        String
  originalTextKey String?   @map("original_text_key") // R2 storage key for original extracted text (used for diffing)
  mondayItemId    String?   @map("monday_item_id")    // for status writeback
  revisionCount   Int       @default(0) @map("revision_count")
  lastVersionAt   DateTime? @map("last_version_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  agency      Agency       @relation(fields: [agencyId],      references: [id], onDelete: Cascade)
  client      Client       @relation(fields: [clientId],      references: [id], onDelete: Cascade)
  run         WorkflowRun  @relation(fields: [runId],         references: [id], onDelete: Cascade)
  stakeholder Stakeholder? @relation(fields: [stakeholderId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([clientId])
  @@index([runId])
  @@map("box_file_trackings")
}

// ─────────────────────────────────────────────
// GoogleDriveFileTracking — links a Google Drive file to a WorkflowRun so
// push-channel notifications can be routed back to the right run/client/stakeholder.
// Channels expire every ≤7 days — the channel renewal cron refreshes them.
// ─────────────────────────────────────────────
model GoogleDriveFileTracking {
  id              String    @id @default(cuid())
  agencyId        String    @map("agency_id")
  clientId        String    @map("client_id")
  runId           String    @map("run_id")
  stakeholderId   String?   @map("stakeholder_id")
  driveFileId     String    @unique @map("drive_file_id")
  driveWebhookChannelId String? @map("drive_webhook_channel_id")  // Google push channel ID
  driveWebhookResourceId String? @map("drive_webhook_resource_id") // returned by Drive on channel registration
  channelExpiry   DateTime? @map("channel_expiry")                 // when the push channel expires
  driveFolderId   String    @map("drive_folder_id")
  filename        String
  originalTextKey String?   @map("original_text_key")
  mondayItemId    String?   @map("monday_item_id")
  revisionCount   Int       @default(0) @map("revision_count")
  lastVersionAt   DateTime? @map("last_version_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  agency      Agency       @relation(fields: [agencyId],      references: [id], onDelete: Cascade)
  client      Client       @relation(fields: [clientId],      references: [id], onDelete: Cascade)
  run         WorkflowRun  @relation(fields: [runId],         references: [id], onDelete: Cascade)
  stakeholder Stakeholder? @relation(fields: [stakeholderId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([clientId])
  @@index([runId])
  @@map("google_drive_file_trackings")
}

// ─────────────────────────────────────────────
// HumanizerSignal — before/after edit pairs attributed to a specific stakeholder.
// Source of truth for per-user style preference learning and humanizer few-shot examples.
// Populated from Box revisions, portal feedback, and manual imports.
// ─────────────────────────────────────────────
model HumanizerSignal {
  id              String   @id @default(cuid())
  agencyId        String   @map("agency_id")
  clientId        String   @map("client_id")
  stakeholderId   String?  @map("stakeholder_id")    // the person whose preferences this reflects (portable across clients)
  runId           String?  @map("run_id")             // the WorkflowRun this edit originated from
  originalText    String   @db.Text @map("original_text")    // AI-generated content before edits
  editedText      String   @db.Text @map("edited_text")      // human-revised content
  diffSummary     String?  @db.Text @map("diff_summary")     // Claude-extracted style rules from the diff
  // box_direct = client edited in Box; box_mediated = employee uploaded client's version;
  // portal_feedback = via ContentNode review portal; import = manual agency import
  source          String   @default("box_direct")
  // stakeholder = known stakeholder; employee = agency staff upload; unknown_external = email not in system yet
  attributedTo    String   @default("stakeholder") @map("attributed_to")
  editorEmail     String?  @map("editor_email")        // raw email from Box — used to retroactively link when stakeholder is added
  boxFileId       String?  @map("box_file_id")        // links back to BoxFileTracking.boxFileId
  documentType    String?  @map("document_type")       // inferred from filename: blog | email | social | ad_copy | landing_page | executive_brief | video_script
  embedding       Unsupported("vector(1536)")? @map("embedding")  // pgvector embedding of originalText — used for few-shot retrieval
  createdAt       DateTime @default(now()) @map("created_at")

  agency      Agency       @relation(fields: [agencyId],      references: [id], onDelete: Cascade)
  client      Client       @relation(fields: [clientId],      references: [id], onDelete: Cascade)
  stakeholder Stakeholder? @relation(fields: [stakeholderId], references: [id], onDelete: SetNull)
  run         WorkflowRun? @relation(fields: [runId],         references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([clientId])
  @@index([stakeholderId])
  @@index([runId])
  @@map("humanizer_signals")
}

// ─────────────────────────────────────────────
// StakeholderPreferenceProfile — per-person content style profile.
// Portable across clients — when a stakeholder moves to a new client,
// this record moves with them (clientId on Stakeholder updates; this stays).
// ─────────────────────────────────────────────
model StakeholderPreferenceProfile {
  id              String   @id @default(cuid())
  stakeholderId   String   @unique @map("stakeholder_id")
  agencyId        String   @map("agency_id")
  // Derived from HumanizerSignal diffs — updated after each processed revision
  // Each array is WeightedSignal[]: { signal, confidence, observedCount, firstSeenAt, lastSeenAt }
  toneSignals     Json     @default("[]") @map("tone_signals")
  structureSignals Json    @default("[]") @map("structure_signals")
  rejectPatterns  Json     @default("[]") @map("reject_patterns")
  approvalRate    Float?   @map("approval_rate")                     // % of runs approved without revision
  revisionCount   Int      @default(0) @map("revision_count")        // total edit pairs processed
  lastSignalAt    DateTime? @map("last_signal_at")                   // when the profile was last updated
  lastDecayAt     DateTime? @map("last_decay_at")                    // when confidence decay was last applied
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lastPrincipleInferredAt DateTime? @map("last_principle_inferred_at")  // gating field — principle inference re-runs every 5 revisions

  stakeholder Stakeholder @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)
  agency      Agency      @relation(fields: [agencyId],      references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@map("stakeholder_preference_profiles")
}

// ─────────────────────────────────────────────
// ClientPreferenceProfile — aggregate editorial style profile for signals where
// the editor identity is unknown. Accumulates WeightedSignals from HumanizerSignals
// with no resolved stakeholderId. Keyed on clientId, one record per client.
// ─────────────────────────────────────────────
model ClientPreferenceProfile {
  id               String    @id @default(cuid())
  clientId         String    @unique @map("client_id")
  agencyId         String    @map("agency_id")
  toneSignals      Json      @default("[]") @map("tone_signals")
  structureSignals Json      @default("[]") @map("structure_signals")
  rejectPatterns   Json      @default("[]") @map("reject_patterns")
  revisionCount    Int       @default(0) @map("revision_count")
  lastSignalAt     DateTime? @map("last_signal_at")
  lastDecayAt      DateTime? @map("last_decay_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  client  Client  @relation(fields: [clientId],  references: [id], onDelete: Cascade)
  agency  Agency  @relation(fields: [agencyId],  references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@map("client_preference_profiles")
}

// ─────────────────────────────────────────────
// StakeholderPrinciple — inferred underlying beliefs that explain WHY a stakeholder
// makes their surface-level edits. One level of abstraction above WeightedSignal.
// Generated by the principle inference job after 5+ confirmed edit pairs.
// Principles generalise across content types the system has never seen the stakeholder edit.
// ─────────────────────────────────────────────
model StakeholderPrinciple {
  id            String   @id @default(cuid())
  agencyId      String   @map("agency_id")
  stakeholderId String   @map("stakeholder_id")

  // e.g. "Distrusts enthusiasm; demands specificity over claims"
  // A belief or value, not a rule.
  principle     String   @db.Text

  // Claude's explanation of which signals led to this inference
  explanation   String   @db.Text

  // 0.0–1.0. Reflects how clearly the signals point to one underlying belief.
  confidence    Float

  // How many HumanizerSignal revision records contributed evidence at last inference
  observedCount Int      @default(1) @map("observed_count")

  // The surface WeightedSignal strings that cluster under this principle (string[])
  supportingSignals Json @default("[]") @map("supporting_signals")

  // Content types this principle generalises to, per Claude's inference (string[])
  contentTypes  Json     @default("[]") @map("content_types")

  // active | dismissed | superseded
  status        String   @default("active")

  // When this principle was last re-evaluated — used to gate re-runs
  lastInferredAt DateTime @map("last_inferred_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stakeholder Stakeholder @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)
  agency      Agency      @relation(fields: [agencyId],      references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([stakeholderId])
  @@map("stakeholder_principles")
}

// ─────────────────────────────────────────────
// ImagePrompt — agency library + client copies
// ─────────────────────────────────────────────
model ImagePrompt {
  id         String    @id @default(cuid())
  agencyId   String    @map("agency_id")
  clientId   String?   @map("client_id")   // null = global agency library
  name       String
  promptText String    @map("prompt_text") @db.Text
  styleTags  String    @default("") @map("style_tags")
  notes      String?   @db.Text
  sortOrder  Int       @default(0) @map("sort_order")
  createdBy  String?   @map("created_by")
  deletedAt  DateTime? @map("deleted_at")
  deletedBy  String?   @map("deleted_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  agency Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([clientId])
  @@map("image_prompts")
}

// PilotSession — persists gtmPILOT conversation transcript per client+vertical.
// Automatically summarized into decisions/rejected/openQuestions after threshold.
// Prior summaries are injected into the system prompt so the PILOT builds on them.
model PilotSession {
  id           String    @id
  agencyId     String    @map("agency_id")
  clientId     String    @map("client_id")
  verticalId   String    @map("vertical_id")
  messages     Json      @default("[]")   // { role: 'user'|'assistant', content: string }[]
  messageCount Int       @default(0) @map("message_count")
  status       String    @default("active")  // active | summarizing | summarized | failed
  summary      Json?                          // { decisions: string[], rejected: string[], openQuestions: string[] }
  createdAt    DateTime  @default(now()) @map("created_at")
  summarizedAt DateTime? @map("summarized_at")

  @@index([agencyId, clientId, verticalId])
  @@index([agencyId, clientId, verticalId, status])
  @@map("pilot_sessions")
}

// ─────────────────────────────────────────────
// ClientBrief — company/product/solution brief library
// Each brief can be associated with one or more verticals.
// Company-level briefs are always injected; product/solution briefs are
// selected per-vertical via ClientFramework.primaryBriefId.
// ─────────────────────────────────────────────
model ClientBrief {
  id               String    @id @default(cuid())
  agencyId         String    @map("agency_id")
  clientId         String    @map("client_id")
  name             String
  type             String    @default("company")    // company | product | solution | service_line
  status           String    @default("draft")      // draft | active
  source           String    @default("pasted")     // uploaded | pasted | pilot_built
  content          String?   @db.Text               // final approved brief text
  extractedData    Json?     @map("extracted_data") // { whatItIs, whoItsFor, problem, outcome, differentiator, buyerContext }
  rawInput         String?   @map("raw_input") @db.Text
  storageKey       String?   @map("storage_key")
  filename         String?
  verticalIds             String[]  @default([]) @map("vertical_ids")
  sharedAcrossVerticals   Boolean   @default(false) @map("shared_across_verticals")
  extractionStatus String    @default("none") @map("extraction_status")  // none | pending | ready | failed
  errorMessage     String?   @map("error_message")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([agencyId, clientId])
  @@map("client_briefs")
}

// ─────────────────────────────────────────────
// TopicQueue — candidate topics from the evaluator awaiting review
// ─────────────────────────────────────────────
model TopicQueue {
  id              String    @id @default(cuid())
  agencyId        String    @map("agency_id")
  clientId        String    @map("client_id")
  verticalId      String?   @map("vertical_id")
  scheduledTaskId String?   @map("scheduled_task_id")
  title           String
  summary         String    @db.Text
  score           Int       @default(0)
  scoreRationale  String    @default("") @map("score_rationale")
  sources         Json      @default("[]")
  status          String    @default("pending") // 'pending' | 'approved' | 'rejected'
  createdAt       DateTime  @default(now()) @map("created_at")
  reviewedAt      DateTime? @map("reviewed_at")

  agency        Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vertical      Vertical?      @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  scheduledTask ScheduledTask? @relation(fields: [scheduledTaskId], references: [id], onDelete: SetNull)
  prefLogs      TopicPreferenceLog[]

  @@index([agencyId, clientId])
  @@index([clientId, verticalId])
  @@index([status])
  @@map("topic_queue")
}

// ─────────────────────────────────────────────
// TopicPreferenceLog — approve/reject history used to train the preference profile
// ─────────────────────────────────────────────
model TopicPreferenceLog {
  id            String    @id @default(cuid())
  agencyId      String    @map("agency_id")
  clientId      String    @map("client_id")
  verticalId    String?   @map("vertical_id")
  topicQueueId  String    @map("topic_queue_id")
  decision      String    // 'approved' | 'rejected'
  title         String
  summary       String    @db.Text
  score         Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")

  agency     Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vertical   Vertical?  @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  topicQueue TopicQueue @relation(fields: [topicQueueId], references: [id], onDelete: Cascade)

  @@index([clientId, verticalId])
  @@index([agencyId])
  @@map("topic_preference_log")
}

// ─────────────────────────────────────────────
// ContentPack — named collection of prompt templates for content generation
// ─────────────────────────────────────────────
model ContentPack {
  id          String   @id @default(cuid())
  agencyId    String   @map("agency_id")
  clientId    String   @map("client_id")
  name        String
  description String?  @db.Text
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items  ContentPackItem[]

  // Back-relations for FK references from Vertical, LeadershipMember, Client
  verticals      Vertical[]         @relation("VerticalDefaultPack")
  members        LeadershipMember[] @relation("MemberDefaultPack")
  clientDefaults Client[]           @relation("ClientDefaultPack")

  @@index([agencyId])
  @@index([clientId])
  @@map("content_packs")
}

// ─────────────────────────────────────────────
// ContentPackItem — ordered join between ContentPack and PromptTemplate
// ─────────────────────────────────────────────
model ContentPackItem {
  id               String   @id @default(cuid())
  contentPackId    String   @map("content_pack_id")
  promptTemplateId String   @map("prompt_template_id")
  order            Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at")

  contentPack    ContentPack    @relation(fields: [contentPackId], references: [id], onDelete: Cascade)
  promptTemplate PromptTemplate @relation(fields: [promptTemplateId], references: [id], onDelete: Cascade)

  @@index([contentPackId])
  @@index([promptTemplateId])
  @@map("content_pack_items")
}

// ─────────────────────────────────────────────
// ContentPackRun — a generation run from the Newsroom assignment flow
// targetType: 'member' | 'vertical' | 'company'
// targetId is a plain String (no Prisma relation) because it can reference
// either a Vertical or a LeadershipMember — resolved in the API by targetType.
// ─────────────────────────────────────────────
model ContentPackRun {
  id             String    @id @default(cuid())
  agencyId       String    @map("agency_id")
  clientId       String    @map("client_id")
  topicId        String?   @map("topic_id")
  topicTitle     String    @map("topic_title")
  topicSummary   String?   @db.Text @map("topic_summary")
  targetType     String    @map("target_type")    // 'member' | 'vertical' | 'company'
  targetId       String?   @map("target_id")      // plain string — no Prisma FK
  targetName     String    @map("target_name")
  packIds        Json      @default("[]") @map("pack_ids")
  packNames      Json      @default("[]") @map("pack_names")
  status         String    @default("pending")     // pending | running | completed | failed
  reviewStatus   String    @default("none") @map("review_status") // none | pending | approved | closed
  assigneeId     String?   @map("assignee_id")
  mondayItemId   String?   @map("monday_item_id")
  mondayBoardId  String?   @map("monday_board_id")
  boxRunFolderId String?   @map("box_run_folder_id")
  errorMessage   String?   @db.Text @map("error_message")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  agency Agency              @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items  ContentPackRunItem[]

  @@index([agencyId])
  @@index([clientId])
  @@index([status])
  @@map("content_pack_runs")
}

// ─────────────────────────────────────────────
// ContentPackRunItem — one generated piece within a ContentPackRun
// ─────────────────────────────────────────────
model ContentPackRunItem {
  id               String    @id @default(cuid())
  runId            String    @map("run_id")
  promptTemplateId String    @map("prompt_template_id")
  promptName       String    @map("prompt_name")
  status           String    @default("pending") // pending | running | completed | failed
  content          String?   @db.Text
  errorMessage     String?   @db.Text @map("error_message")
  mondaySubItemId  String?   @map("monday_sub_item_id")
  boxFileId        String?   @map("box_file_id")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  run            ContentPackRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  promptTemplate PromptTemplate @relation(fields: [promptTemplateId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("content_pack_run_items")
}
