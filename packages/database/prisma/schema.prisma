  lastCrawledAt    DateTime? @map("last_crawled_at")
  crawledSnapshot  Json      @default("{}") @map("crawled_snapshot")
  sources          Json      @default("[]") @map("sources")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@map("company_profiles")
}

// ─────────────────────────────────────────────
// PMAgentMemory — persistent brain for the ContentNode PM agent
// Stores learned routing rules, answered questions, capacity patterns,
// and assignment preferences. Never deleted — confidence updates in place.
// ─────────────────────────────────────────────
model PMAgentMemory {
  id         String   @id @default(cuid())
  agencyId   String   @map("agency_id")

  // category: routing_rule | capacity_pattern | assignment_preference | answered_question | behavior_observation
  category   String
  // key: human-readable identifier e.g. "rapid_manual_runs_workflow_xyz" or "assignee_john_content_type_blog"
  key        String

  // value: the learned fact / rule / preference as structured JSON
  value      Json

  // confidence 0.0-1.0 — increases as pattern repeats
  confidence Float    @default(0.5)

  // How many times this pattern has been observed
  observedCount Int   @default(1) @map("observed_count")

  // If this came from a user answering a PM question — what was asked and answered
  questionAsked  String? @map("question_asked")
  userAnswer     String? @map("user_answer")

  // Scope — some memories are workflow-specific, some are global
  workflowId String? @map("workflow_id")
  userId     String? @map("user_id")       // which user triggered the pattern
  clientId   String? @map("client_id")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, category, key])
  @@index([agencyId])
  @@index([agencyId, category])
  @@index([agencyId, workflowId])
  @@map("pm_agent_memory")
}

// ─────────────────────────────────────────────
// PMAgentNotification — a question or observation surfaced by the PM agent
// to a human. Answered notifications feed PMAgentMemory.
// ─────────────────────────────────────────────
model PMAgentNotification {
  id          String   @id @default(cuid())
  agencyId    String   @map("agency_id")

  // type: question | observation | alert
  type        String   @default("question")

  // Pattern that triggered this
  patternKey  String   @map("pattern_key")  // e.g. "rapid_manual_runs"
  title       String
  body        String   @db.Text

  // Context for rendering actions
  context     Json     @default("{}")

  // Actions offered to the user: [{ label, value, memoryValue }]
  actions     Json     @default("[]")

  // Status: pending | answered | dismissed | auto_resolved
  status      String   @default("pending")
  answeredAt  DateTime? @map("answered_at")
  answeredBy  String?   @map("answered_by")  // userId
  chosenAction String?  @map("chosen_action")
  alwaysApply  Boolean  @default(false) @map("always_apply") // "always do this" was chosen

  // Linked to a specific run if relevant
  workflowRunId String? @map("workflow_run_id")
  workflowId    String? @map("workflow_id")

  createdAt   DateTime @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([agencyId, status])
  @@index([agencyId, workflowId])
  @@map("pm_agent_notifications")
}

// ─────────────────────────────────────────────
// ClientProfile — brand voice, audience, visual identity for a client
// One profile per client; created on first GET (upsert).
// Three data layers: crawled | historical | client_direct (manual overrides win).
// ─────────────────────────────────────────────
model ClientProfile {
  id        String   @id @default(cuid())
  agencyId  String   @map("agency_id")
  clientId  String   @map("client_id")

  label  String? // user-assigned label, defaults to crawledFrom domain
  status String  @default("active") // active | archived

  // Brand voice
  brandTone        String? @map("brand_tone")
  formality        String? // formal | semi-formal | casual
  pov              String? // first_person | second_person | third_person
  signaturePhrases Json    @default("[]") @map("signature_phrases")  // string[]
  avoidPhrases     Json    @default("[]") @map("avoid_phrases")      // string[]

  // Audience
  primaryBuyer     Json    @default("{}") @map("primary_buyer")      // { title, age_range, pain_points, goals }
  secondaryBuyer   Json    @default("{}") @map("secondary_buyer")
  buyerMotivations Json    @default("[]") @map("buyer_motivations")  // string[]
  buyerFears       Json    @default("[]") @map("buyer_fears")        // string[]

  // Visual identity
  visualStyle                String? @map("visual_style")             // clean_modern | bold_expressive | etc.
  colorTemperature           String? @map("color_temperature")        // warm | cool | neutral
  photographyVsIllustration  String? @map("photography_vs_illustration") // photography | illustration | mixed
  approvedVisualThemes       Json    @default("[]") @map("approved_visual_themes") // string[]
  avoidVisual                Json    @default("[]") @map("avoid_visual")            // string[]

  // Strategic
  currentPositioning     String? @map("current_positioning")
  campaignThemesApproved Json    @default("[]") @map("campaign_themes_approved") // string[]

  // Manual overrides — each: { field, instruction, source, confidence, date, expires? }
  manualOverrides Json @default("[]") @map("manual_overrides")

  // Confidence map — per field: "crawled" | "historical" | "client_direct"
  confidenceMap Json @default("{}") @map("confidence_map")

  // Source metadata
  crawledFrom      String?   @map("crawled_from")
  lastCrawledAt    DateTime? @map("last_crawled_at")
  crawledSnapshot  Json      @default("{}") @map("crawled_snapshot")
  sources          Json      @default("[]") @map("sources")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@map("client_profiles")
}

// AgencyFile — org-level "library" files usable across all clients
// ─────────────────────────────────────────────
model AgencyFile {
  id           String   @id @default(cuid())
  agencyId     String   @map("agency_id")
  originalName String   @map("original_name")
  storageKey   String   @map("storage_key")
  label        String?
  category     String?  // brand-guidelines | instructions | standards | templates | other
  sizeBytes    Int      @default(0) @map("size_bytes")
  createdAt    DateTime @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@map("agency_files")
}

// ─────────────────────────────────────────────
// ClientWorkflowFiles — per-workflow file bindings (isolated from template)
