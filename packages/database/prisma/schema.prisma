generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Agency — top-level tenant
// ─────────────────────────────────────────────
model Agency {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  clerkOrgId String? @unique @map("clerk_org_id")
  plan      String   @default("starter")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clients            Client[]
  stakeholders       Stakeholder[]
  users              User[]
  workflows          Workflow[]
  documents          Document[]
  usageRecords       UsageRecord[]
  usageEvents        UsageEvent[]
  auditLogs          AuditLog[]
  transcriptSessions TranscriptSession[]
  insights           Insight[]
  humanizerExamples  HumanizerExample[]
  writerAssignments  WriterAssignment[]
  workflowSchedules  WorkflowSchedule[]
  deliverableAccess  DeliverableAccess[]
  settings           AgencySettings?
  agencyFiles        AgencyFile[]
  clientFiles        ClientFile[]
  promptTemplates    PromptTemplate[]
  clientProfiles     ClientProfile[]
  companyProfiles    CompanyProfile[]
  pmAgentMemory      PMAgentMemory[]
  pmAgentNotifications PMAgentNotification[]
  divisions          Division[]
  jobs               Job[]
  clientDemandGen      ClientDemandGen[]
  clientDemandGenBase  ClientDemandGenBase[]
  clientGTMAssessments ClientGTMAssessment[]
  clientFrameworks   ClientFramework[]
  kitSessions        KitSession[]
  clientVerticals    ClientVertical[]
  verticals          Vertical[]
  frameworkAttachments ClientFrameworkAttachment[]
  frameworkResearch    ClientFrameworkResearch[]
  brandVerticals     ClientBrandVertical[]
  brandProfiles      ClientBrandProfile[]
  brandBuilders      ClientBrandBuilder[]
  brandAttachments   ClientBrandAttachment[]
  manualUsageEntries ManualUsageEntry[]
  campaigns          Campaign[]
  scheduledTasks     ScheduledTask[]
  clientDocStyles    ClientDocStyle[]
  docTemplates       DocTemplate[]
  docTemplateAssignments DocTemplateAssignment[]
  prospectAssessments    ProspectAssessment[]
  assessmentSnapshots    AssessmentSnapshot[]
  agencyBrainAttachments         AgencyBrainAttachment[]
  verticalBrainAttachments       VerticalBrainAttachment[]
  clientVerticalBrainAttachments ClientVerticalBrainAttachment[]
  leadershipMembers              LeadershipMember[]
  notifications                  Notification[]
  integrations                   Integration[]
  mondayWebhooks                 MondayWebhook[]
  skillSessionTemplates          SkillSessionTemplate[]
  frameworkRevisions             FrameworkRevision[]
  boxFileTrackings               BoxFileTracking[]
  googleDriveFileTrackings       GoogleDriveFileTracking[]
  humanizerSignals               HumanizerSignal[]
  stakeholderPreferenceProfiles  StakeholderPreferenceProfile[]
  clientPreferenceProfiles       ClientPreferenceProfile[]
  stakeholderPrinciples          StakeholderPrinciple[]
  clientBriefs                   ClientBrief[]
  // Permissions override — if null, role defaults apply.
  // See PermissionService for resolution order.
  permissionsOverride Json? @map("permissions_override")
  brainContext        String? @db.Text @map("brain_context")
  programs                 Program[]
  programContentPacks      ProgramContentPack[]
  verticalProgramTemplates VerticalProgramTemplate[]
  agencyCredentials        AgencyCredential[]
  imagePrompts             ImagePrompt[]
  topicQueue               TopicQueue[]
  topicPreferenceLogs      TopicPreferenceLog[]
  researchJobs             ResearchJob[]
  contentPacks             ContentPack[]
  contentPackRuns          ContentPackRun[]

  @@map("agencies")
}

model AgencyCredential {
  id        String   @id @default(cuid())
  agencyId  String   @map("agency_id")
  provider  String   // e.g. "sendgrid", "resend", "mailgun"
  keyName   String   @map("key_name")   // human label, e.g. "SendGrid Production"
  keyValue  String   @db.Text @map("key_value")  // AES-256-GCM encrypted
  meta      Json?    // extra config, e.g. { mailgunDomain, fromEmail }
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, provider, keyName])
  @@map("agency_credentials")
}

// ─────────────────────────────────────────────
// AgencySettings — org-level configuration
// ─────────────────────────────────────────────
model AgencySettings {
  id                      String   @id @default(cuid())
  agencyId                String   @unique @map("agency_id")
  // Temp contacts: null = never expire, otherwise days until auto-archive
  tempContactExpiryDays   Int?     @map("temp_contact_expiry_days")
  // DOCX style defaults — used by all document downloads unless overridden per-client
  docLogoStorageKey       String?  @map("doc_logo_storage_key")
  docPrimaryColor         String   @default("#1B1F3B") @map("doc_primary_color")
  docSecondaryColor       String   @default("#4A90D9") @map("doc_secondary_color")
  docHeadingFont          String   @default("Calibri") @map("doc_heading_font")
  docBodyFont             String   @default("Calibri") @map("doc_body_font")
  docAgencyName           String?  @map("doc_agency_name")
  docCoverPage            Boolean  @default(true) @map("doc_cover_page")
  docPageNumbers          Boolean  @default(true) @map("doc_page_numbers")
  docFooterText           String?  @map("doc_footer_text")
  docApplyToGtm           Boolean  @default(true) @map("doc_apply_to_gtm")
  docApplyToDemandGen     Boolean  @default(false) @map("doc_apply_to_demand_gen")
  docApplyToBranding      Boolean  @default(false) @map("doc_apply_to_branding")
  ollamaModels            Json     @default("[]") @map("ollama_models") // retained for schema compat — moved to users.ollama_models
  verticalTerm            String   @default("Vertical") @map("vertical_term")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("agency_settings")
}

// ClientDocStyle — per-client DOCX style overrides (null = inherit from AgencySettings)
// ─────────────────────────────────────────────
model ClientDocStyle {
  id               String   @id @default(cuid())
  agencyId         String   @map("agency_id")
  clientId         String   @unique @map("client_id")
  logoStorageKey   String?  @map("logo_storage_key")
  primaryColor     String?  @map("primary_color")
  secondaryColor   String?  @map("secondary_color")
  headingFont      String?  @map("heading_font")
  bodyFont         String?  @map("body_font")
  agencyName       String?  @map("agency_name")
  coverPage        Boolean? @map("cover_page")
  pageNumbers      Boolean? @map("page_numbers")
  footerText       String?  @map("footer_text")
  applyToGtm       Boolean? @map("apply_to_gtm")
  applyToDemandGen Boolean? @map("apply_to_demand_gen")
  applyToBranding  Boolean? @map("apply_to_branding")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@map("client_doc_styles")
}

// ─────────────────────────────────────────────
// Client — an agency's end-client
// ─────────────────────────────────────────────
model Client {
  id             String    @id @default(cuid())
  agencyId       String    @map("agency_id")
  name           String
  slug           String
  industry       String?
  logoStorageKey String?   @map("logo_storage_key")
  status         String    @default("active") // active | archived
  archivedAt     DateTime? @map("archived_at")
  requireOffline      Boolean @default(false) @map("require_offline")
  isOrgClient         Boolean @default(false) @map("is_org_client") // Agency's own company — fallback for org-level workflows
  // Permissions override for all users working with this client.
  // Merged after the agency-level override; before user-level override.
  permissionsOverride Json?   @map("permissions_override")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  agency       Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  stakeholders Stakeholder[]
  workflows    Workflow[]
  documents    Document[]
  transcriptSessions TranscriptSession[]
  insights     Insight[]
  clientFiles     ClientFile[]
  promptTemplates PromptTemplate[]
  profiles        ClientProfile[]
  companyProfiles CompanyProfile[]
  divisions    Division[]
  demandGen       ClientDemandGen[]
  demandGenBase   ClientDemandGenBase?
  gtmAssessment   ClientGTMAssessment?
  frameworks      ClientFramework[]
  kitSessions     KitSession[]
  clientVerticals ClientVertical[]
  frameworkAttachments ClientFrameworkAttachment[]
  frameworkResearch    ClientFrameworkResearch[]
  brandVerticals   ClientBrandVertical[]
  brandProfiles    ClientBrandProfile[]
  brandBuilders    ClientBrandBuilder[]
  brandAttachments   ClientBrandAttachment[]
  manualUsageEntries ManualUsageEntry[]
  campaigns          Campaign[]
  brainAttachments   ClientBrainAttachment[]
  scheduledTasks     ScheduledTask[]
  usageRecords       UsageRecord[]
  clientVerticalBrainAttachments ClientVerticalBrainAttachment[]
  brainContext       String?  @db.Text @map("brain_context")
  boxFolderId        String?  @map("box_folder_id")    // Box folder ID for this client's root folder
  googleDriveFolderId String? @map("google_drive_folder_id") // Google Drive folder ID for this client's root folder
  mondayBoardId      String?  @map("monday_board_id")  // Monday board ID for this client (for Board→Client mapping)
  docStyle           ClientDocStyle?
  leadershipMembers  LeadershipMember[]
  frameworkRevisions FrameworkRevision[]
  boxFileTrackings   BoxFileTracking[]
  googleDriveFileTrackings GoogleDriveFileTracking[]
  humanizerSignals   HumanizerSignal[]
  programs            Program[]
  programContentPacks ProgramContentPack[]
  preferenceProfile   ClientPreferenceProfile?
  imagePrompts        ImagePrompt[]
  clientBriefs        ClientBrief[]
  topicQueue          TopicQueue[]
  topicPreferenceLogs TopicPreferenceLog[]
  researchJobs        ResearchJob[]
  defaultContentPackId       String?  @map("default_content_pack_id")
  contentMondayBoardId       String?  @map("content_monday_board_id")
  contentMondayColumnMapping Json?    @map("content_monday_column_mapping")
  contentBoxFolderId         String?  @map("content_box_folder_id")
  defaultContentPack         ContentPack? @relation("ClientDefaultPack", fields: [defaultContentPackId], references: [id], onDelete: SetNull)
  contentPacks               ContentPack[]
  contentPackRuns            ContentPackRun[]

  @@unique([agencyId, slug])
  @@index([agencyId])
  @@map("clients")
}

// ─────────────────────────────────────────────
// Vertical — agency-level GTM verticals
// ─────────────────────────────────────────────
model Vertical {
  id            String   @id @default(cuid())
  agencyId      String   @map("agency_id")
  name          String
  dimensionType String   @default("vertical") @map("dimension_type")
  color         String?  @db.VarChar(7)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  agency     Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  demandGen            ClientDemandGen[]
  frameworks           ClientFramework[]
  kitSessions          KitSession[]
  clientVerticals      ClientVertical[]
  frameworkAttachments ClientFrameworkAttachment[]
  frameworkResearch    ClientFrameworkResearch[]
  brainAttachments     VerticalBrainAttachment[]
  scheduledTasks       ScheduledTask[]
  clientVerticalBrainAttachments ClientVerticalBrainAttachment[]
  workflows            Workflow[]
  brainContext         String? @db.Text @map("brain_context")
  frameworkRevisions       FrameworkRevision[]
  programs                 Program[]
  programTemplates         VerticalProgramTemplate[]
  topicQueue               TopicQueue[]
  topicPreferenceLogs      TopicPreferenceLog[]
  researchJobs             ResearchJob[]
  targetAudience       String?  @db.Text @map("target_audience")
  toneDescriptors      String[] @map("tone_descriptors")
  keyMessages          String[] @map("key_messages")
  voiceAvoidPhrases    String[] @map("voice_avoid_phrases")
  defaultContentPackId String?  @map("default_content_pack_id")
  mondayBoardId        String?  @map("monday_board_id")
  mondayColumnMapping  Json?    @map("monday_column_mapping")
  boxFolderId          String?  @map("box_folder_id")
  defaultContentPack   ContentPack? @relation("VerticalDefaultPack", fields: [defaultContentPackId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@map("verticals")
}

// ─────────────────────────────────────────────
// ClientVertical — which verticals a client operates in
// ─────────────────────────────────────────────
model ClientVertical {
  id         String   @id @default(cuid())
  agencyId   String   @map("agency_id")
  clientId   String   @map("client_id")
  verticalId String   @map("vertical_id")
  createdAt  DateTime @default(now()) @map("created_at")

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vertical Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@unique([clientId, verticalId])
  @@index([agencyId])
  @@map("client_verticals")
}

// ─────────────────────────────────────────────
// ClientDemandGen — per-client demand generation data
// ─────────────────────────────────────────────
model ClientDemandGen {
  id         String   @id @default(cuid())
  agencyId   String   @map("agency_id")
  clientId   String   @map("client_id")
  verticalId String   @map("vertical_id")
  data       Json     @default("{}")
  updatedAt  DateTime @updatedAt @map("updated_at")
  createdAt  DateTime @default(now()) @map("created_at")

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vertical Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@unique([clientId, verticalId])
  @@index([agencyId])
  @@map("client_demand_gen")
}

// ─────────────────────────────────────────────
// ClientDemandGenBase — company-wide demand gen context
// ─────────────────────────────────────────────
model ClientDemandGenBase {
  id        String   @id @default(cuid())
  agencyId  String   @map("agency_id")
  clientId  String   @map("client_id")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId])
  @@index([agencyId])
  @@map("client_demand_gen_base")
}

// ClientGTMAssessment — structured prospect / client GTM intake assessment
// ─────────────────────────────────────────────
model ClientGTMAssessment {
  id        String   @id @default(cuid())
  agencyId  String   @map("agency_id")
  clientId  String   @map("client_id")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId])
  @@index([agencyId])
  @@map("client_gtm_assessments")
}

// ─────────────────────────────────────────────
// ClientFramework — per-client-per-vertical GTM content engine
// ─────────────────────────────────────────────
model ClientFramework {
  id              String   @id @default(cuid())
  agencyId        String   @map("agency_id")
  clientId        String   @map("client_id")
  verticalId      String   @map("vertical_id")
  data            Json     @default("{}")
  sectionStatus   Json     @default("{}") @map("section_status")
  primaryBriefId  String?  @map("primary_brief_id")  // active product/solution brief for this vertical
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdAt       DateTime @default(now()) @map("created_at")

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vertical Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@unique([clientId, verticalId])
  @@index([agencyId])
  @@map("client_frameworks")
}

// ─────────────────────────────────────────────
// ClientFrameworkAttachment — files attached to a client+vertical framework
// ─────────────────────────────────────────────
model ClientFrameworkAttachment {
  id            String   @id @default(cuid())
  agencyId      String   @map("agency_id")
  clientId      String   @map("client_id")
  verticalId    String   @map("vertical_id")
  filename      String
  storageKey    String   @map("storage_key")
  mimeType      String   @map("mime_type")
  sizeBytes     Int      @map("size_bytes")
  // pending | processing | ready | failed
  summaryStatus String   @default("pending") @map("summary_status")
  extractedText String?  @map("extracted_text") @db.Text
  summary       String?  @db.Text  // Claude's structured interpretation — user-editable
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vertical Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@index([clientId, verticalId])
  @@index([agencyId])
  @@map("client_framework_attachments")
}

// ─────────────────────────────────────────────
// ClientFrameworkResearch — cached research context per client+vertical
// ─────────────────────────────────────────────
model ClientFrameworkResearch {
  id               String    @id @default(cuid())
  agencyId         String    @map("agency_id")
  clientId         String    @map("client_id")
  verticalId       String    @map("vertical_id")
  // pending | running | ready | failed
  status           String    @default("pending")
  sources          Json      @default("[]")  // DocumentSource[]
  websiteUrl       String?   @map("website_url")
  companyBrief     String?   @map("company_brief") @db.Text
  errorMessage     String?   @map("error_message") @db.Text
  researchedAt     DateTime? @map("researched_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vertical Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@unique([clientId, verticalId])
  @@index([agencyId])
  @@map("client_framework_research")
}

// ─────────────────────────────────────────────
// ClientFrameworkResearchRun — versioned research runs per client+vertical
// ─────────────────────────────────────────────
model ClientFrameworkResearchRun {
  id             String    @id @default(cuid())
  agencyId       String    @map("agency_id")
  clientId       String    @map("client_id")
  verticalId     String    @map("vertical_id")
  // pending | running | ready | failed
  status         String    @default("pending")
  // established | new_vertical
  researchMode   String    @default("established") @map("research_mode")
  sectionResults Json?     @map("section_results")
  sources        Json      @default("[]")
  errorMessage   String?   @map("error_message") @db.Text
  mergedFromIds  String[]  @default([]) @map("merged_from_ids")
  researchedAt   DateTime? @map("researched_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([clientId, verticalId])
  @@index([agencyId])
  @@map("client_framework_research_runs")
}

// ─────────────────────────────────────────────
// ClientFrameworkUploadedGtm — client-supplied GTM upload + conflict analysis
// ─────────────────────────────────────────────
model ClientFrameworkUploadedGtm {
  id                String    @id @default(cuid())
  agencyId          String    @map("agency_id")
  clientId          String    @map("client_id")
  verticalId        String    @map("vertical_id")
  storageKey        String    @map("storage_key")
  filename          String
  // processing | ready | failed
  status            String    @default("processing")
  extractedSections Json?     @map("extracted_sections")
  conflictLog       Json?     @map("conflict_log")
  errorMessage      String?   @map("error_message") @db.Text
  uploadedAt        DateTime  @default(now()) @map("uploaded_at")
  processedAt       DateTime? @map("processed_at")

  @@index([clientId, verticalId])
  @@index([agencyId])
  @@map("client_framework_uploaded_gtms")
}

// ─────────────────────────────────────────────
// KitSession — GTM Kit Generator session state
// ─────────────────────────────────────────────
model KitSession {
  id             String   @id @default(cuid())
  agencyId       String   @map("agency_id")
  clientId       String   @map("client_id")
  verticalId     String   @map("vertical_id")
  // 'full' | 'quick'
  mode           String   @default("full")
  // 'intake' | 'asset_01' .. 'asset_08' | 'delivery' | 'complete'
  status         String   @default("intake")
  currentAsset   Int?     @map("current_asset")
  approvedAssets Json     @default("[]") @map("approved_assets")
  chatHistory    Json     @default("[]") @map("chat_history")
  intakeJson     Json?    @map("intake_json")
  generatedFiles       Json     @default("{}") @map("generated_files")
  storyboardImageCache Json     @default("{}") @map("storyboard_image_cache")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vertical Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([clientId, verticalId])
  @@map("kit_sessions")
}

// ─────────────────────────────────────────────
// Stakeholder — client-side contacts
// ─────────────────────────────────────────────
model Stakeholder {
  id         String    @id @default(cuid())
  agencyId   String    @map("agency_id")
  clientId   String    @map("client_id")
  name       String
  email      String
  role       String?
  seniority  String    @default("member") // owner | senior | member | junior — used for collective insight weighting
  source     String    @default("manual") @map("source") // manual | deliverable_share
  expiresAt  DateTime? @map("expires_at") // set for deliverable_share contacts based on agency settings
  archivedAt DateTime? @map("archived_at")
  magicLinkToken     String?   @unique @map("magic_link_token")
  magicLinkExpiresAt DateTime? @map("magic_link_expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  feedbacks Feedback[]
  transcriptSessions   TranscriptSession[]
  transcriptSegments   TranscriptSegment[]
  deliverableAccess    DeliverableAccess[]
  boxFileTrackings     BoxFileTracking[]
  googleDriveFileTrackings GoogleDriveFileTracking[]
  humanizerSignals     HumanizerSignal[]
  preferenceProfile    StakeholderPreferenceProfile?
  principles           StakeholderPrinciple[]

  @@unique([clientId, email])
  @@index([agencyId])
  @@index([clientId])
  @@map("stakeholders")
}

// ─────────────────────────────────────────────
// User — agency team member (authenticated via Clerk)
// ─────────────────────────────────────────────
model User {
  id         String   @id @default(cuid())
  agencyId   String   @map("agency_id")
  clerkUserId String  @unique @map("clerk_user_id")
  email      String
  name       String?
  title             String?
  department        String?
  avatarStorageKey  String?  @map("avatar_storage_key")
  // Roles: owner | admin | lead | member (existing) + super_admin | org_admin | client_manager | editor | reviewer | viewer | api_user (new)
  role       String   @default("member")
  // Per-user permission override. Highest priority in the resolution chain.
  // If null, inherits from client → agency → role defaults.
  permissionsOverride Json? @map("permissions_override")
  // Local Ollama model names for this user's machine — populates model picker datalists
  ollamaModels        Json     @default("[]") @map("ollama_models")
  // Local media service endpoints (TTS, image gen, character animation, transcription)
  localMediaServices  Json     @default("[]") @map("local_media_services")
  inviteToken     String?   @unique @map("invite_token")
  inviteExpiresAt DateTime? @map("invite_expires_at")
  lastActiveAt    DateTime? @map("last_active_at") // updated on every authenticated request (throttled to 5 min)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  agency       Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  workflowRuns         WorkflowRun[] @relation("RunTriggeredBy")
  assignedRuns         WorkflowRun[] @relation("RunAssignee")
  defaultAssigneeOf    Workflow[]    @relation("WorkflowDefaultAssignee")
  comments             Comment[]
  notifications        Notification[]
  assignedScheduledTasks ScheduledTask[] @relation("ScheduledTaskAssignee")

  @@index([agencyId])
  @@map("users")
}

// ─────────────────────────────────────────────
// Workflow — a node-based automation graph
// ─────────────────────────────────────────────
model Workflow {
  id               String   @id @default(cuid())
  agencyId         String   @map("agency_id")
  clientId         String?  @map("client_id")
  name             String
  description      String?
  connectivityMode String   @default("online") @map("connectivity_mode") // online | offline — locked after first run
  status           String   @default("draft") // draft | active | archived
  version          Int      @default(1)
  firstRunAt       DateTime? @map("first_run_at") // connectivity_mode locked after this is set
  projectName      String?   @map("project_name")
  itemName         String?   @map("item_name")
  mondayGroupId    String?   @map("monday_group_id")
  mondayGroupName  String?   @map("monday_group_name")
  boxProjectFolderId          String? @map("box_project_folder_id")
  googleDriveProjectFolderId  String? @map("google_drive_project_folder_id")
  isTemplate       Boolean   @default(false) @map("is_template")
  templateCategory String?   @map("template_category")
  templateDescription String? @map("template_description")
  templateCreatedBy String?   @map("template_created_by")
  isLocked         Boolean   @default(false) @map("is_locked")
  defaultAssigneeId String?   @map("default_assignee_id")
  verticalId        String?   @map("vertical_id")
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  agency          Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  defaultAssignee User?     @relation("WorkflowDefaultAssignee", fields: [defaultAssigneeId], references: [id])
  vertical        Vertical? @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  nodes            Node[]
  edges            Edge[]
  runs             WorkflowRun[]
  schedules        WorkflowSchedule[]
  campaignWorkflows CampaignWorkflow[]

  @@index([agencyId])
  @@index([clientId])
  @@index([verticalId])
  @@map("workflows")
}

// ─────────────────────────────────────────────
// WorkflowSchedule — cron-based auto-trigger
// ─────────────────────────────────────────────
model WorkflowSchedule {
  id         String    @id @default(cuid())
  agencyId   String    @map("agency_id")
  workflowId String    @map("workflow_id")
  name       String?
  cronExpr   String    @map("cron_expr")
  timezone   String    @default("UTC")
  status     String    @default("active")   // active | paused
  nextRunAt  DateTime? @map("next_run_at")
  lastRunAt  DateTime? @map("last_run_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([workflowId])
  @@index([status, nextRunAt])
  @@map("workflow_schedules")
}

// ─────────────────────────────────────────────
// Division — a subdivision of a client (e.g. department, brand)
// ─────────────────────────────────────────────
model Division {
  id        String   @id @default(cuid())
  agencyId  String   @map("agency_id")
  clientId  String   @map("client_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agency Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  jobs   Job[]
  runs   WorkflowRun[]

  @@index([agencyId])
  @@index([clientId])
  @@map("divisions")
}

// ─────────────────────────────────────────────
// Job — a project/campaign within a division
// ─────────────────────────────────────────────
model Job {
  id          String   @id @default(cuid())
  agencyId    String   @map("agency_id")
  divisionId  String   @map("division_id")
  name        String
  budgetCents Int?     @map("budget_cents")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  division Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  runs     WorkflowRun[]

  @@index([agencyId])
  @@index([divisionId])
  @@map("jobs")
}

// ─────────────────────────────────────────────
// Node — a single node in a workflow graph
// ─────────────────────────────────────────────
model Node {
  id         String   @id @default(cuid())
  agencyId   String   @map("agency_id")
  workflowId String   @map("workflow_id")
  type       String   // e.g. "ai-generate", "human-review", "transform"
  label      String?
  config     Json     @default("{}")
  positionX  Float    @default(0) @map("position_x")
  positionY  Float    @default(0) @map("position_y")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  workflow       Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceEdges    Edge[]        @relation("source")
  targetEdges    Edge[]        @relation("target")

  @@index([agencyId])
  @@index([workflowId])
  @@map("nodes")
}

// ─────────────────────────────────────────────
// Edge — directed connection between two nodes
// ─────────────────────────────────────────────
model Edge {
  id           String   @id @default(cuid())
  agencyId     String   @map("agency_id")
  workflowId   String   @map("workflow_id")
  sourceNodeId String   @map("source_node_id")
  targetNodeId String   @map("target_node_id")
  label        String?
  condition    Json?    // optional conditional routing config
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceNode Node     @relation("source", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode Node     @relation("target", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([workflowId])
  @@map("edges")
}

// ─────────────────────────────────────────────
// Document — content artifact produced or consumed by workflows
// ─────────────────────────────────────────────
model Document {
  id         String   @id @default(cuid())
  agencyId   String   @map("agency_id")
  clientId   String   @map("client_id")
  workflowRunId String? @map("workflow_run_id")
  name       String
  mimeType   String?  @map("mime_type")
  storageKey String?  @map("storage_key") // R2 / local path
  sizeBytes  Int?     @map("size_bytes")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  agency      Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workflowRun WorkflowRun? @relation(fields: [workflowRunId], references: [id])
  feedbacks   Feedback[]

  @@index([agencyId])
  @@index([clientId])
  @@map("documents")
}

// ─────────────────────────────────────────────
// WorkflowRun — a single execution of a workflow
// ─────────────────────────────────────────────
model WorkflowRun {
  id          String    @id @default(cuid())
  agencyId    String    @map("agency_id")
  workflowId  String    @map("workflow_id")
  triggeredBy         String?   @map("triggered_by") // User id or "system"
  status              String    @default("pending") // pending | running | completed | failed | cancelled | waiting_feedback | awaiting_assignment
  triggerType         String?   @map("trigger_type") // manual | feedback_auto
  reentryFromNodeId   String?   @map("reentry_from_node_id")
  parentRunId         String?   @map("parent_run_id")
  input               Json      @default("{}")
  output              Json      @default("{}")
  errorMessage        String?   @map("error_message")
  startedAt           DateTime? @map("started_at")
  completedAt         DateTime? @map("completed_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  batchId             String?   @map("batch_id")
  batchIndex          Int?      @map("batch_index")
  reviewStatus        String    @default("none") @map("review_status") // none | pending | sent_to_client | client_responded | closed
  reviewerIds         Json      @default("[]") @map("reviewer_ids")   // stakeholder IDs assigned to review
  contentHash         String?   @map("content_hash")  // SHA-256 of all source node content — groups runs of same input
  divisionId          String?   @map("division_id")
  jobId               String?   @map("job_id")
  itemName            String?   @map("item_name")
  itemVersion         Int       @default(1) @map("item_version")
  editedContent       Json?     @map("edited_content") // { [nodeId]: string } — agency-polished text per output node

  assigneeId          String?   @map("assignee_id")
  internalNotes       String?   @map("internal_notes")
  dueDate             DateTime? @map("due_date")
  campaignId          String?   @map("campaign_id")
  programId           String?   @map("program_id")

  // Deliverables board fields
  priority            String?   // high | medium | low
  statusExternal      String?   @db.Text @map("status_external")
  followupStatus      String?   @db.Text @map("followup_status")
  mainClientName      String?   @map("main_client_name")
  otherStakeholders   String?   @db.Text @map("other_stakeholders")
  teamDesign          String?   @map("team_design")
  teamContent         String?   @map("team_content")
  teamVideo           String?   @map("team_video")
  sowNumber           String?   @map("sow_number")
  budgetMs            Decimal?  @map("budget_ms") @db.Decimal(10, 2)
  mainCategory        String?   @map("main_category")
  focus               String?
  clientFolderBox     String?   @db.Text @map("client_folder_box")
  clientFolderClient  String?   @db.Text @map("client_folder_client")
  mondayItemId        String?   @map("monday_item_id")
  mondayBoardId       String?   @map("monday_board_id")
  mondaySubItemId     String?   @map("monday_sub_item_id")
  topic               String?

  // Delivery lifecycle — set by PM agent or manual "mark as delivered"
  deliveredAt              DateTime? @map("delivered_at")
  deliveryBoxFileId        String?   @map("delivery_box_file_id")   // Box file ID of the authoritative delivered version
  deliveredBoxFolderId     String?   @map("delivered_box_folder_id") // Box folder ID where the file was delivered (denorm for version scoring)
  deliveryGoogleDriveFileId   String? @map("delivery_google_drive_file_id")   // Google Drive file ID of the delivered version
  deliveredGoogleDriveFolderId String? @map("delivered_google_drive_folder_id")
  deliveredContentHash     String?   @map("delivered_content_hash")  // SHA-256 of the exact text delivered to Box (not source hash)
  isArchived               Boolean   @default(false) @map("is_archived") // true = iteration run, hidden from Reviews by default

  workflow          Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  campaign          Campaign?             @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  program           Program?              @relation(fields: [programId], references: [id], onDelete: SetNull)
  user              User?                 @relation("RunTriggeredBy", fields: [triggeredBy], references: [id])
  assignee          User?                 @relation("RunAssignee", fields: [assigneeId], references: [id])
  documents         Document[]
  feedbacks         Feedback[]
  qualityRecord     ContentQualityRecord?
  writerAssignments WriterAssignment[]
  deliverableAccess DeliverableAccess[]
  division          Division?             @relation(fields: [divisionId], references: [id])
  job               Job?                  @relation(fields: [jobId], references: [id])
  comments          Comment[]
  boxFileTrackings  BoxFileTracking[]
  googleDriveFileTrackings GoogleDriveFileTracking[]
  humanizerSignals  HumanizerSignal[]

  @@index([agencyId])
  @@index([workflowId])
  @@index([batchId])
  @@index([divisionId])
  @@index([jobId])
  @@index([campaignId])
  @@index([programId])
  @@map("workflow_runs")
}

// ─────────────────────────────────────────────
// DeliverableAccess — per-run external access grants (Box.com model)
// Each record gives one stakeholder access to one specific WorkflowRun.
// Revocation sets revokedAt; record is kept for audit trail.
// ─────────────────────────────────────────────
model DeliverableAccess {
  id            String    @id @default(cuid())
  agencyId      String    @map("agency_id")
  runId         String    @map("run_id")
  stakeholderId String    @map("stakeholder_id")
  token         String    @unique
  expiresAt     DateTime? @map("expires_at")
  revokedAt     DateTime? @map("revoked_at")
  grantedBy     String?   @map("granted_by") // User.clerkUserId
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  run         WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  stakeholder Stakeholder @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)

  @@unique([runId, stakeholderId])
  @@index([agencyId])
  @@index([runId])
  @@index([stakeholderId])
  @@index([token])
  @@map("deliverable_access")
}

// ─────────────────────────────────────────────
// ContentQualityRecord — quality signals captured after each workflow run
// One record per completed run; used for quality learning + recommendations.
// ─────────────────────────────────────────────
model ContentQualityRecord {
  id         String   @id @default(cuid())
  agencyId   String   @map("agency_id")
  workflowId String   @map("workflow_id")
  clientId   String?  @map("client_id")
  runId      String   @unique @map("run_id")
  createdAt  DateTime @default(now()) @map("created_at")

  // Content characteristics (from content-output node config)
  contentType String? @map("content_type") // blog_post | email | ad_copy | etc.
  wordCount   Int?    @map("word_count")

  // Detection quality — array of { nodeId, scoreBefore, scoreAfter, retryCount, service, threshold, passed }
  detectionScores Json @default("[]") @map("detection_scores")

  // AI generation — array of { nodeId, model, provider, taskType, tokensUsed }
  aiGenerations Json @default("[]") @map("ai_generations")

  // Humanizer runs — array of { nodeId, service, mode, wordsProcessed }
  humanizerRuns Json @default("[]") @map("humanizer_runs")

  // Stakeholder feedback (updated when feedback arrives for this run)
  stakeholderRating Float?  @map("stakeholder_rating") // avg 1-5
  feedbackDecision  String? @map("feedback_decision")   // approved | needs_revision | rejected | etc.
  feedbackCount     Int     @default(0) @map("feedback_count")

  run      WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([agencyId, workflowId])
  @@index([agencyId, clientId])
  @@index([createdAt])
  @@map("content_quality_records")
}

// ─────────────────────────────────────────────
// Comment — internal team comment on a workflow run (not visible to clients)
// ─────────────────────────────────────────────
model Comment {
  id            String      @id @default(cuid())
  agencyId      String      @map("agency_id")
  workflowRunId String      @map("workflow_run_id")
  userId        String      @map("user_id")
  body          String
  createdAt     DateTime    @default(now()) @map("created_at")

  workflowRun   WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])

  @@index([workflowRunId])
  @@index([agencyId])
  @@map("comments")
}

// ─────────────────────────────────────────────
// Feedback — stakeholder review of a document or run, OR a quote extracted from a transcript
// ─────────────────────────────────────────────
model Feedback {
  id                  String   @id @default(cuid())
  agencyId            String   @map("agency_id")
  documentId          String?  @map("document_id")
  workflowRunId       String?  @map("workflow_run_id")
  stakeholderId       String?  @map("stakeholder_id")
  decision            String?  // approved | approved_with_changes | needs_revision | rejected | null (for transcript quotes)
  comment             String?
  // Structured portal feedback fields
  starRating          Int?     @map("star_rating")           // 1-5
  toneFeedback        String?  @map("tone_feedback")         // too_formal | too_casual | just_right | too_generic
  contentTags         Json     @default("[]") @map("content_tags")      // too_long | too_short | missing_points | off_brief | good
  specificChanges     Json     @default("[]") @map("specific_changes")  // [{text, instruction, startOffset?, endOffset?}]
  outputDecisions     Json     @default("{}") @map("output_decisions") // {[nodeId]: {decision, comment}}
  // Transcript quote fields (populated when feedback comes from quote extraction)
  transcriptSessionId String?  @map("transcript_session_id")
  transcriptSegmentId String?  @map("transcript_segment_id")
  quoteText           String?  @map("quote_text")
  category            String?  // pain_point | desire | objection | insight | action_item | source_material | other
  createdAt           DateTime @default(now()) @map("created_at")

  // Feedback is immutable — no updatedAt
  document      Document?    @relation(fields: [documentId], references: [id])
  workflowRun   WorkflowRun? @relation(fields: [workflowRunId], references: [id])
  stakeholder   Stakeholder? @relation(fields: [stakeholderId], references: [id])

  @@index([agencyId])
  @@index([documentId])
  @@index([workflowRunId])
  @@index([transcriptSessionId])
  @@map("feedbacks")
}

// ─────────────────────────────────────────────
// TranscriptSession — a recorded meeting/interview session
// ─────────────────────────────────────────────
model TranscriptSession {
  id            String    @id @default(cuid())
  agencyId      String    @map("agency_id")
  clientId      String    @map("client_id")
  stakeholderId String?   @map("stakeholder_id")
  workflowRunId String?   @map("workflow_run_id")  // linked workflow run (if triggered via node)
  nodeId        String?   @map("node_id")           // transcription node that triggered this
  targetNodeIds Json      @default("[]") @map("target_node_ids") // downstream nodes to receive transcript
  title         String?
  recordingUrl  String?   @map("recording_url")
  status        String    @default("pending") // pending | processing | awaiting_assignment | ready | failed
  durationSecs  Int?      @map("duration_secs")
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  agency      Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stakeholder Stakeholder? @relation(fields: [stakeholderId], references: [id])
  segments    TranscriptSegment[]
  insights    Insight[]

  @@index([agencyId])
  @@index([clientId])
  @@map("transcript_sessions")
}

// ─────────────────────────────────────────────
// TranscriptSegment — a timestamped chunk of a transcript
// ─────────────────────────────────────────────
model TranscriptSegment {
  id                  String   @id @default(cuid())
  agencyId            String   @map("agency_id")
  sessionId           String   @map("session_id")
  speaker             String?  // raw diarization label (e.g. "0", "1")
  speakerName         String?  @map("speaker_name")          // human-assigned display name
  stakeholderId       String?  @map("stakeholder_id")        // assigned stakeholder (nullable = unassigned)
  isAgencyParticipant Boolean  @default(false) @map("is_agency_participant") // agency employee flag
  audioClipKey        String?  @map("audio_clip_key")        // storage key for 10-second representative clip
  startMs             Int      @map("start_ms")
  endMs               Int      @map("end_ms")
  text                String
  embedding           Unsupported("vector(1536)")?  // pgvector embedding
  createdAt           DateTime @default(now()) @map("created_at")

  session     TranscriptSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stakeholder Stakeholder?      @relation(fields: [stakeholderId], references: [id])

  @@index([agencyId])
  @@index([sessionId])
  @@map("transcript_segments")
}

// ─────────────────────────────────────────────
// Insight — AI-derived insight from transcripts or workflows
// Pattern intelligence insights are generated by the pattern detector.
// ─────────────────────────────────────────────
model Insight {
  id        String   @id @default(cuid())
  agencyId  String   @map("agency_id")
  clientId  String   @map("client_id")
  sessionId String?  @map("session_id")
  // type: theme | action_item | sentiment | risk | opportunity | tone | forbidden_term | structure | length | claims
  type      String
  title     String
  body      String
  confidence Float?
  // Pattern intelligence fields
  status              String   @default("pending")  // pending | applied | confirmed | dismissed
  instanceCount       Int      @default(1)           @map("instance_count")
  stakeholderIds      Json     @default("[]")        @map("stakeholder_ids")   // string[]
  isCollective        Boolean  @default(false)       @map("is_collective")
  evidenceQuotes      Json     @default("[]")        @map("evidence_quotes")   // { text, stakeholderId, stakeholderName, runId }[]
  suggestedNodeType   String?                        @map("suggested_node_type")  // e.g. "logic:humanizer"
  suggestedConfigChange Json   @default("{}")        @map("suggested_config_change")
  connectedNodeId     String?                        @map("connected_node_id") // canvas node ID
  baselineScore       Float?                         @map("baseline_score")    // avg star_rating before application
  postApplicationScore Float?                        @map("post_application_score")
  appliedRunCount     Int      @default(0)           @map("applied_run_count")
  dismissedUntilRun   Int?                           @map("dismissed_until_run")
  appliedAt           DateTime?                      @map("applied_at")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agency  Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client  Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  session TranscriptSession? @relation(fields: [sessionId], references: [id])

  @@index([agencyId])
  @@index([clientId])
  @@index([agencyId, clientId, status])
  @@map("insights")
}

// ─────────────────────────────────────────────
// UsageRecord — metered billing / quota tracking
// ─────────────────────────────────────────────
model UsageRecord {
  id              String   @id @default(cuid())
  agencyId        String   @map("agency_id")
  clientId        String?  @map("client_id")
  scheduledTaskId String?  @map("scheduled_task_id")
  metric          String   // ai_tokens | workflow_runs | storage_bytes | research_brief_searches | …
  quantity        Float
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")

  agency        Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client        Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  scheduledTask ScheduledTask? @relation(fields: [scheduledTaskId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([clientId])
  @@index([scheduledTaskId])
  @@index([agencyId, metric, periodStart])
  @@map("usage_records")
}

// ─────────────────────────────────────────────
// UsageEvent — granular per-execution event log
// Immutable: never update. Corrections write a new event with `corrects` set.
// ─────────────────────────────────────────────
model UsageEvent {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())

  // Identity
  userId   String? @map("user_id")    // Clerk user ID of the triggering user
  userRole String? @map("user_role")
  clientId String? @map("client_id")
  agencyId String  @map("agency_id")

  // Tool category
  toolType    String @map("tool_type")    // llm | graphics | video | content
  toolSubtype String @map("tool_subtype") // text_generation | image_generation | video_generation | humanizer | …

  // Provider / model used
  provider String
  model    String
  isOnline Boolean @map("is_online") // true = cloud, false = local/offline

  // Workflow context
  workflowId    String? @map("workflow_id")
  workflowRunId String? @map("workflow_run_id")
  nodeId        String? @map("node_id")
  nodeType      String? @map("node_type")

  // Input / output metrics (nullable — not all fields apply to all tool types)
  inputTokens        Int?   @map("input_tokens")
  outputTokens       Int?   @map("output_tokens")
  inputCharacters    Int?   @map("input_characters")
  outputCharacters   Int?   @map("output_characters")
  inputMediaCount    Int?   @map("input_media_count")
  outputMediaCount   Int?   @map("output_media_count")
  outputDurationSecs Float? @map("output_duration_secs")
  outputResolution   String? @map("output_resolution")

  // Cost
  estimatedCostUsd Float? @map("estimated_cost_usd")

  // Execution
  durationMs   Int    @map("duration_ms")
  status       String // success | error | cancelled
  errorCode    String? @map("error_code")
  errorMessage String? @map("error_message")

  // Snapshot of the user's resolved permissions at execution time (audit trail).
  // Allows reconstruction of why a capability was or was not allowed.
  permissionsAtTime Json? @map("permissions_at_time")

  // Correction chain: if this event corrects a prior event, set its id here.
  // The original event is never mutated.
  corrects String?

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([agencyId, userId])
  @@index([agencyId, clientId])
  @@index([agencyId, workflowRunId])
  @@index([agencyId, toolType])
  @@index([agencyId, timestamp])
  @@map("usage_events")
}

// ─────────────────────────────────────────────
// AuditLog — append-only compliance trail
// ─────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  agencyId   String   @map("agency_id")
  actorType  String   @map("actor_type") // user | stakeholder | system
  actorId    String?  @map("actor_id")
  action     String   // e.g. "workflow.run.created", "document.approved"
  resourceType String? @map("resource_type")
  resourceId   String? @map("resource_id")
  metadata   Json     @default("{}")
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  // Append-only: no updatedAt, no soft-delete
  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([agencyId, action])
  @@index([agencyId, resourceType, resourceId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// WriterAssignment — assigns a completed run to a writer for human polish
// Writer receives a magic link to edit the AI draft and submit their version.
// Submission creates a HumanizerExample for cnHumanizer training.
// ─────────────────────────────────────────────
model WriterAssignment {
  id                   String    @id @default(cuid())
  agencyId             String    @map("agency_id")
  workflowRunId        String    @map("workflow_run_id")
  writerEmail          String    @map("writer_email")
  writerName           String?   @map("writer_name")
  magicLinkToken       String?   @unique @map("magic_link_token")
  magicLinkExpiresAt   DateTime? @map("magic_link_expires_at")
  status               String    @default("pending") // pending | submitted
  submittedContent     String?   @map("submitted_content")
  submittedAt          DateTime? @map("submitted_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([workflowRunId])
  @@map("writer_assignments")
}

// ─────────────────────────────────────────────
// HumanizerExample — before/after pairs for few-shot Claude humanizer training
// Collected automatically from every third-party humanizer run.
// Writer-uploaded examples can also be added manually (source='writer').
// ─────────────────────────────────────────────
model HumanizerExample {
  id                   String   @id @default(cuid())
  agencyId             String   @map("agency_id")
  contentBefore        String?  @map("content_before")   // null for writer uploads (before lives in run output)
  contentAfter         String   @map("content_after")
  wordCountBefore      Int?     @map("word_count_before")
  wordCountAfter       Int      @map("word_count_after")
  detectionScoreBefore Float?   @map("detection_score_before")
  detectionScoreAfter  Float?   @map("detection_score_after")
  service              String   // undetectable | bypassgpt | stealthgpt | claude-humanizer | writer
  source               String   @default("third-party") // third-party | writer
  workflowRunId        String?  @map("workflow_run_id")
  approved             Boolean  @default(false)
  createdAt            DateTime @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([agencyId, detectionScoreAfter])
  @@index([agencyId, service])
  @@map("humanizer_examples")
}

// ─────────────────────────────────────────────
// PromptTemplate — reusable instruction sets for AI nodes
// ─────────────────────────────────────────────
model PromptTemplate {
  id                   String   @id @default(cuid())
  agencyId             String   @map("agency_id")
  clientId             String?  @map("client_id")              // null = Global Library
