#!/usr/bin/env bash
# Block direct pushes to main. Use: git push origin main:staging instead.

while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    echo ""
    echo "❌  Direct push to main is blocked."
    echo "    Push to staging first: git push origin main:staging"
    echo "    Then merge staging → main via GitHub PR when ready for production."
    echo ""
    exit 1
  fi
done

exit 0
